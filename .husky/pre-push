#!/usr/bin/env sh

remote="$1"
url="$2"

while read local_ref local_oid remote_ref remote_oid
do
  if echo "$remote_ref" | grep -qE "refs/heads/master$"; then
    echo ""
    echo "🚫  Direct push to master is blocked."
    echo "    Create a branch and open a PR instead."
    echo ""
    echo "    To bypass (force push only): git push --force --no-verify"
    echo ""
    exit 1
  fi
done

exit 0
