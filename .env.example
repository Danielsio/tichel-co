# ──────────────────────────────────────────────
# Tichel & Co. — Environment Variables
# Copy to .env.local and fill in real values
# ──────────────────────────────────────────────

# ━━ REQUIRED ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── App ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=he

# ── Firebase Emulators (local dev only) ────────
# NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true

# ── Firebase (Client — safe to expose) ─────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firestore Database ID ────────────────────────
# Defaults to "tichel-co-db". Set to "tichel-co-db-eu" (europe-west4) for co-located perf.
FIRESTORE_DATABASE_ID=tichel-co-db
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=tichel-co-db

# ── Firebase Admin (Server only — never expose) ──
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Payments (Stripe — test mode) ─────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend — free tier, 3k/month) ──────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@tichelco.com

# ━━ OPTIONAL / FUTURE ━━━━━━━━━━━━━━━━━━━━━━━━

# ── Search (Algolia — free tier, 10k requests/mo)
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
# ALGOLIA_ADMIN_KEY=

# ── Error Tracking (Sentry — deferred to post-launch)
# SENTRY_DSN=

# ── Analytics (PostHog — deferred to post-launch)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
