rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.role == "admin";
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── Products: anyone reads published, admins can write ──
    match /products/{productId} {
      allow read: if resource.data.publishedAt != null || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;

      match /variants/{variantId} {
        allow read: if true;
        allow create, update: if isAdmin();
        allow delete: if false;
      }
    }

    // ── Collections: anyone reads published, admins can write ──
    match /collections/{collectionId} {
      allow read: if resource.data.publishedAt != null || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ── Users: owner can read/write own profile ──
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Orders: owner reads own, admins read all, writes via API only ──
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Cart: owner can read/write own cart ──
    match /cart/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Custom Requests: anyone creates, owner reads own, admins read/update all ──
    match /customRequests/{requestId} {
      allow create: if true;
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Reviews: anyone reads published, owner creates ──
    match /reviews/{reviewId} {
      allow read: if resource.data.publishedAt != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // ── Discount Codes: read-only from client ──
    match /discountCodes/{code} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
